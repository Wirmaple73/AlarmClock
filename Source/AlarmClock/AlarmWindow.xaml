<Window x:Class="AlarmClock.AlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="زنگ هشدار" Height="320" Width="300" TextOptions.TextFormattingMode="Display" FontFamily="Tahoma" Background="WhiteSmoke" Topmost="True" ResizeMode="NoResize" Icon="icon_alarmclock.ico" Closing="Window_Closing">
    <Grid FlowDirection="RightToLeft">
        <Label Content="زنگ هشدار" Margin="10,4,10,0" VerticalAlignment="Top" FontSize="25" HorizontalContentAlignment="Center"/>
        <Label x:Name="Label_CurrentTime" Content="زمان" Margin="10,41,10,0" VerticalAlignment="Top" HorizontalContentAlignment="Center" FontSize="22" ToolTip="زمان زنگ هشدار"/>
        <Separator Height="14" Margin="10,74,10,0" VerticalAlignment="Top"/>
        <Label Content="عنوان:" Margin="10,96,10,0" VerticalAlignment="Top"/>
        <TextBox x:Name="TextBox_AlarmTitle" Height="119" Margin="10,120,10,0" TextWrapping="Wrap" VerticalAlignment="Top" VerticalScrollBarVisibility="Auto" IsReadOnly="True" ToolTip="عنوان (دلیل) هشدار"/>
        <Button Content="بستن" Margin="18,247,189,0" VerticalAlignment="Top" Height="26" Click="Button_OK_Click" FontSize="13" IsCancel="True" IsDefault="True" ToolTip="بازگشت به پنجره اصلی"/>
    </Grid>
</Window>
