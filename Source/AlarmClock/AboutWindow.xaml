        <Label Content="علیرضا شهیدی فرد" HorizontalAlignment="Left" Margin="170,66,0,0" VerticalAlignment="Top"/>
        <TextBlock x:Name="TextBlock_GithubLink" HorizontalAlignment="Left" Margin="99,90,0,0" TextWrapping="Wrap" Text="https://github.com/Wirmaple73" VerticalAlignment="Top" Cursor="Hand" Foreground="Blue" TextDecorations="Underline" MouseDown="TextBlock_GithubLink_MouseDown" ToolTip="مشاهده پروفایل گیت‌هاب"/>
        <Button Content="بازگشت" Margin="183,163,20,0" VerticalAlignment="Top" Height="28" Click="Button_OK_Click" FontSize="13" IsCancel="True" IsDefault="True" ToolTip="بازگشت به پنجره اصلی"/>

